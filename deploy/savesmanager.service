[Unit]
Description=SavesManager (Nuxt SSR)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/savesmanager
EnvironmentFile=-/opt/savesmanager/savesmanager.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /opt/savesmanager/.output/server/index.mjs
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
